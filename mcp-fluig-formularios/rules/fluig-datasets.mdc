### Tipo 4: REST Assíncrono

**Quando usar:**
- Volume alto/muito alto (> 1.000 registros)
- Query complexa com muitos JOINs e cálculos
- Dados podem ter delay
- Relatórios gerenciais, dashboards, cargas

```javascript
/**
 * [NOME_DATASET] - [DESCRIÇÃO]
 * Tipo: REST Assíncrono
 * Autor: [AUTOR]
 * Data: [DATA]
 * Serviço: [NOME_SERVICO_REST]
 * Endpoint: [ENDPOINT]
 * Sincronização: [FREQUÊNCIA]
 */
var init = {
    datasetName: '[NOME_DATASET]',
    fluigService: 'BANCORBRAS_REST_SLL',
    endpoint: '/EXECQUERY/SELECT',
    method: 'post',
    params: {
        execquery: ''
    }
};

function defineStructure() {
    addColumn("CAMPO1");
    addColumn("CAMPO2");
    addColumn("CAMPO3");
    
    setKey(["CAMPO1"]);
    addIndex(["CAMPO1", "CAMPO2"]);
}

function onSync(lastSyncDate) {
    var dataset = DatasetBuilder.newDataset();

    var cnsquery = " "
        + "SELECT "
        + "    CAMPO1 = RTRIM(T.CAMPO1), "
        + "    CAMPO2 = RTRIM(T.CAMPO2), "
        + "    CAMPO3 = RTRIM(T.CAMPO3) "
        + "FROM "
        + "    TABELA T WITH (NOLOCK) "
        + "WHERE "
        + "    T.D_E_L_E_T_ = '' ";

    init.params.execquery = cnsquery;

    var service = fluigAPI.getAuthorizeClientService();
    var options = {
        companyId: getValue('WKCompany') + '',
        serviceCode: init.fluigService,
        endpoint: init.endpoint,
        method: init.method,
        params: init.params,
        timeoutService: '100',
        headers: {
            Connection: 'close'
        }
    };

    try {
        var response = service.invoke(new org.json.JSONObject(options).toString());
        var data = JSON.parse(response.getResult());

        if (data && data.result && data.result.length > 0) {
            dataset.addColumn("CAMPO1");
            dataset.addColumn("CAMPO2");
            dataset.addColumn("CAMPO3");

            for (var i = 0; i < data.result.length; i++) {
                dataset.addOrUpdateRow([
                    data.result[i]["CAMPO1"] || "",
                    data.result[i]["CAMPO2"] || "",
                    data.result[i]["CAMPO3"] || ""
                ]);
            }
        }

    } catch (e) {
        log.error("ERRO [NOME_DATASET] onSync: " + e.message);
    }

    return dataset;
}

function createDataset(fields, constraints, sortFields) {
    // Apenas retorna dados do cache sincronizado
}
```

