### Tipo 2: JDBC Assíncrono

**Quando usar:**
- Volume médio/alto (500 - 10.000 registros)
- Query média complexidade
- Dados podem ter delay (sincronização por scheduler)
- Relatórios, dashboards

```javascript
/**
 * [NOME_DATASET] - [DESCRIÇÃO]
 * Tipo: JDBC Assíncrono
 * Autor: [AUTOR]
 * Data: [DATA]
 * Sincronização: [FREQUÊNCIA - Ex: A cada 1 hora]
 */
function defineStructure() {
    addColumn("CAMPO1");
    addColumn("CAMPO2");
    addColumn("CAMPO3");
    
    setKey(["CAMPO1"]); // Chave única para update
    addIndex(["CAMPO1", "CAMPO2"]); // Índices para busca
}

function onSync(lastSyncDate) {
    var dataset = DatasetBuilder.newDataset();
    var dataSource = "/jdbc/protheusSql";
    var ic = new javax.naming.InitialContext();
    var ds = ic.lookup(dataSource);

    var myQuery = " "
        + "SELECT "
        + "    CAMPO1 = RTRIM(T.CAMPO1), "
        + "    CAMPO2 = RTRIM(T.CAMPO2), "
        + "    CAMPO3 = RTRIM(T.CAMPO3) "
        + "FROM "
        + "    TABELA T WITH (NOLOCK) "
        + "WHERE "
        + "    T.D_E_L_E_T_ = '' ";

    try {
        var conn = ds.getConnection();
        var stmt = conn.createStatement();
        var resultCns = stmt.executeQuery(myQuery);

        dataset.addColumn("CAMPO1");
        dataset.addColumn("CAMPO2");
        dataset.addColumn("CAMPO3");

        while (resultCns.next()) {
            dataset.addOrUpdateRow([
                resultCns.getString("CAMPO1") || "",
                resultCns.getString("CAMPO2") || "",
                resultCns.getString("CAMPO3") || ""
            ]);
        }

    } catch (e) {
        log.error("ERRO [NOME_DATASET] onSync: " + e.message);
    } finally {
        if (resultCns != null) resultCns.close();
        if (stmt != null) stmt.close();
        if (conn != null) conn.close();
    }

    return dataset;
}

function createDataset(fields, constraints, sortFields) {
    // Apenas retorna dados do cache sincronizado
}
```

