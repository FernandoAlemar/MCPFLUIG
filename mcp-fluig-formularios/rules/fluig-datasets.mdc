### Tipo 3: REST Síncrono

**Quando usar:**
- Volume baixo/médio
- Query complexa (melhor executar no Protheus)
- Dados em tempo real necessários
- Zoom de formulários, validações

```javascript
/**
 * [NOME_DATASET] - [DESCRIÇÃO]
 * Tipo: REST Síncrono
 * Autor: [AUTOR]
 * Data: [DATA]
 * Serviço: [NOME_SERVICO_REST]
 * Endpoint: [ENDPOINT]
 */
function createDataset(fields, constraints, sortFields) {
    var dataset = DatasetBuilder.newDataset();

    // Parâmetros
    var param1 = "";
    if (constraints != null && constraints.length > 0) {
        for (var i = 0; i < constraints.length; i++) {
            if (constraints[i].fieldName == 'param1') {
                param1 = constraints[i].initialValue;
            }
        }
    }

    var clientService = fluigAPI.getAuthorizeClientService();

    var data = {
        companyId: getValue('WKCompany') + '',
        serviceCode: 'BANCORBRAS_REST',
        endpoint: '/ENDPOINT?param=' + param1,
        method: 'get',
        timeoutService: '100'
    };

    try {
        var vo = clientService.invoke(JSON.stringify(data));
        var objdata = JSON.parse(vo.getResult());

        dataset.addColumn("CAMPO1");
        dataset.addColumn("CAMPO2");

        if (objdata.Code == 200 && objdata.result) {
            for (var i = 0; i < objdata.result.length; i++) {
                dataset.addRow([
                    objdata.result[i].CAMPO1 || "",
                    objdata.result[i].CAMPO2 || ""
                ]);
            }
        }

    } catch (e) {
        log.error("ERRO [NOME_DATASET]: " + e.message);
        dataset.addColumn('error');
        dataset.addRow(['Erro: ' + e.message]);
    }

    return dataset;
}
```

