## 3. Templates por Tipo

### Tipo 1: JDBC Síncrono

**Quando usar:**
- Volume baixo (< 500 registros)
- Query simples (1-3 tabelas)
- Dados em tempo real necessários
- Zoom de formulários simples

```javascript
/**
 * [NOME_DATASET] - [DESCRIÇÃO]
 * Tipo: JDBC Síncrono
 * Autor: [AUTOR]
 * Data: [DATA]
 */
function createDataset(fields, constraints, sortFields) {
    var dataset = DatasetBuilder.newDataset();
    var dataSource = "/jdbc/protheusSql";
    var ic = new javax.naming.InitialContext();
    var ds = ic.lookup(dataSource);
    var created = false;

    // Parâmetros
    var param1 = "";
    if (constraints != null && constraints.length > 0) {
        for (var i = 0; i < constraints.length; i++) {
            if (constraints[i].fieldName == 'param1') {
                param1 = constraints[i].initialValue;
            }
        }
    }

    var myQuery = " "
        + "SELECT "
        + "    CAMPO1 = RTRIM(TABELA.CAMPO1), "
        + "    CAMPO2 = RTRIM(TABELA.CAMPO2) "
        + "FROM "
        + "    TABELA WITH (NOLOCK) "
        + "WHERE "
        + "    D_E_L_E_T_ = '' "
        + "    AND CAMPO1 = '" + param1 + "' ";

    try {
        var conn = ds.getConnection();
        var stmt = conn.createStatement();
        var resultCns = stmt.executeQuery(myQuery);
        var columnCount = resultCns.getMetaData().getColumnCount();

        while (resultCns.next()) {
            if (!created) {
                for (var i = 1; i <= columnCount; i++) {
                    dataset.addColumn(resultCns.getMetaData().getColumnName(i));
                }
                created = true;
            }

            var Arr = new Array();
            for (var i = 1; i <= columnCount; i++) {
                var obj = resultCns.getObject(resultCns.getMetaData().getColumnName(i));
                Arr[i - 1] = (obj != null) ? obj.toString().trim() : "";
            }
            dataset.addRow(Arr);
        }

    } catch (e) {
        log.error("ERRO [NOME_DATASET]: " + e.message);
        dataset.addColumn('error');
        dataset.addRow(['Erro: ' + e.message]);
    } finally {
        if (resultCns != null) resultCns.close();
        if (stmt != null) stmt.close();
        if (conn != null) conn.close();
    }

    return dataset;
}
```

